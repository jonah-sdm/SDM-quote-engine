# --- Telegram quote bot ---
# From @BotFather
TELEGRAM_BOT_TOKEN=
# Random string; passed to setWebhook and verified on every incoming update
TELEGRAM_WEBHOOK_SECRET=
# Numeric chat id of the sales group the bot is allowed to operate in (negative for groups)
TELEGRAM_ALLOWED_GROUP_ID=
# Upstash Redis (HTTP) — free tier is fine
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Used only by scripts/set-telegram-webhook.js
TELEGRAM_WEBHOOK_URL=https://your-vercel-deployment.vercel.app/api/telegram
